{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [[ \"$f\" =~ \\.(js|css|html)$ ]] && ./node_modules/.bin/prettier --write \"$f\"; } 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
